{
  "name": "bridgefill",
  "version": "0.1.0",
  "description": "Schema registry and code generator for API integrations",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "test:e2e": "tsx test/e2e.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.cjs"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/websocket": "^8.3.1",
    "fastify": "^4.26.2",
    "jsonwebtoken": "^9.0.2",
    "pino-pretty": "^11.0.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.9.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
